  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --ts-config tsconfig.unit-test.json --include src/app/components/",
    "test:watch": "ng test --ts-config tsconfig.unit-test.json --include src/app/components/",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --project chromium --headed",
    "prettier": "prettier --write \"**/*.{js,json,css,scss,less,md,ts,html}\"",
    "update": "ncu -u",
    "prepare": "npx playwright install"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
